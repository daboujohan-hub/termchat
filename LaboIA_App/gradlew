#!/bin/sh

##############################################################################
# Gradle start up script for Termux / UNIX
##############################################################################

DEFAULT_JVM_OPTS=-Xmx1536m

APP_NAME="Gradle"
APP_BASE_NAME=$(basename "$0")

# Resolve links: $0 may be a link
PRG="$0"
while [ -h "$PRG" ] ; do
    ls=$(ls -ld "$PRG")
    link=$(expr "$ls" : '.*-> \(.*\)$')
    if expr "$link" : '/.*' > /dev/null; then
        PRG="$link"
    else
        PRG=$(dirname "$PRG")"/$link"
    fi
done
SAVED="$(pwd)"
cd "$(dirname "$PRG")/" >/dev/null
APP_HOME="$(pwd -P)"
cd "$SAVED" >/dev/null

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine the Java command to use
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        echo "ERREUR: JAVA_HOME est défini sur un emplacement invalide: $JAVA_HOME" >&2
        exit 1
    fi
else
    # JAVA_HOME absent : on cherche Java directement par chemin, sans dépendre
    # de la commande 'which' (cassée sur certaines installations Termux).
    JAVACMD=""
    for candidate in \
        "${PREFIX:-/data/data/com.termux/files/usr}/bin/java" \
        "${PREFIX:-/data/data/com.termux/files/usr}/lib/jvm/java-21-openjdk/bin/java" \
        "${PREFIX:-/data/data/com.termux/files/usr}/lib/jvm/java-17-openjdk/bin/java" \
        "/usr/bin/java" \
        "/usr/lib/jvm/default-java/bin/java"
    do
        if [ -x "$candidate" ] ; then
            JAVACMD="$candidate"
            break
        fi
    done

    if [ -z "$JAVACMD" ] ; then
        # Dernier recours : test direct via 'command -v' (POSIX, fonctionne
        # même quand le binaire externe 'which' est cassé).
        if command -v java >/dev/null 2>&1 ; then
            JAVACMD="java"
        else
            echo "ERREUR: Java introuvable automatiquement." >&2
            echo "Installez Java avec : pkg install openjdk-21 (Termux)" >&2
            echo "Ou définissez JAVA_HOME manuellement, par exemple :" >&2
            echo "  export JAVA_HOME=\${PREFIX}/lib/jvm/java-21-openjdk" >&2
            exit 1
        fi
    fi
fi

exec "$JAVACMD" $DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
