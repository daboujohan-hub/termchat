<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#FF6B00</item>
        <item name="colorPrimaryDark">#030810</item>
        <item name="colorAccent">#FFD700</item>
        <item name="android:windowBackground">#030810</item>
        <item name="android:statusBarColor">#030810</item>
        <item name="android:navigationBarColor">#030810</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="SplashTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">#030810</item>
        <item name="android:statusBarColor">#030810</item>
        <item name="android:navigationBarColor">#030810</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

</resources>
