<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#030810"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LABO IA"
        android:textColor="#FF6B00"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:fontFamily="sans-serif-condensed"
        android:layout_gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TERMUX ACADEMY"
        android:textColor="#FFD700"
        android:textSize="16sp"
        android:letterSpacing="0.12"
        android:layout_marginTop="4dp"
        android:layout_gravity="center" />

    <View
        android:layout_width="80dp"
        android:layout_height="2dp"
        android:background="#FF6B00"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:layout_gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v7.0 · Côte d'Ivoire 🇨🇮"
        android:textColor="#80F0E8D8"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_gravity="center" />

    <ProgressBar
        android:layout_width="160dp"
        android:layout_height="4dp"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_marginTop="40dp"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:progressTint="#FF6B00"
        android:indeterminateTint="#FF6B00" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="// Formation des développeurs africains"
        android:textColor="#50F0E8D8"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:layout_marginTop="16dp"
        android:layout_gravity="center" />

</LinearLayout>
